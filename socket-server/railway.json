{
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10
  },
  "variables": {
    "NODE_ENV": "production",
    "FRONTEND_URL": "https://saas-frontend-gules.vercel.app"
  }
}
